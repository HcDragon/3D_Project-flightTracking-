DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: PostgreSQL
# DATABASE_URL=postgresql://worldpulse:worldpulse@localhost:5432/worldpulse
# Optional: Redis for multi-process Channels
# REDIS_URL=redis://127.0.0.1:6379/0
# Optional: higher OpenSky rate limits
# OPENSKY_USER=
# OPENSKY_PASS=
WORLDPULSE_UPDATE_INTERVAL=10
WORLDPULSE_ALERT_ZONE=25,55,-80,-20
